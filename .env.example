# Application
APP_NAME="AI Doctor Booking"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database (Docker postgres on port 5433)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=ai_doctor
DB_USERNAME=postgres
DB_PASSWORD=secret

# Redis (local Redis on 6379, no password)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=secret
REDIS_PORT=6379

# JWT
JWT_SECRET=

# Internal API Secret (Backend <-> AI Service communication)
BACKEND_API_SECRET=change_this_secret_key_32chars_xx

# ─── FREE AI SERVICES ──────────────────────────────────────────────────────────
# Groq API (Free tier) — https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# ─── TELEPHONY (Twilio Free Trial) ────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── EMAIL ────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_FROM_ADDRESS=noreply@aidoctorbooking.com
MAIL_FROM_NAME="AI Doctor Booking"

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME="AI Doctor Booking"
